@page
@model HealthApp.Razor.Pages.Doctor.ConfirmationModel
@{
    ViewData["Title"] = "Confirmer les rendez-vous";
}

<h1>Confirm appointments</h1>

@if (Model.Appointments.Count == 0)
{
    <p>No appointments to confirm.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Date</th>
                <th>Patient</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var appointment in Model.Appointments)
            {
                <tr>
                    <td>@DateTimeOffset.FromUnixTimeMilliseconds(appointment.DateTimeMilli).ToString("dd/MM/yyyy HH:mm")</td>
                    <td>@appointment.UserId.Substring(0, 8)</td>
                    <td>
                        <form method="post">
                            <input type="hidden" name="appointmentId" value="@appointment.Id" />
                            <button type="submit" asp-page-handler="Confirm" class="btn btn-success">Confirm</button>
                            <button type="submit" asp-page-handler="Cancel" class="btn btn-danger">Cancel</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
